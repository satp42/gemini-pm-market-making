# Gemini API
GEMINI_API_KEY=your-api-key-here
GEMINI_API_SECRET=your-api-secret-here
GEMINI_ENV=sandbox

# Avellaneda-Stoikov Parameters
AS_GAMMA=0.1
AS_K=1.5
AS_SIGMA_DEFAULT=0.01
AS_VARIANCE_WINDOW=100

# Bot Behavior
BOT_CYCLE_SECONDS=10
SCANNER_CYCLE_SECONDS=300
MIN_SPREAD=0.03
MIN_TIME_TO_EXPIRY_HOURS=1
EXCLUDED_SYMBOLS=

# Risk Limits
MAX_INVENTORY_PER_SYMBOL=200
MAX_TOTAL_EXPOSURE=1000
RISK_WIDEN_THRESHOLD=0.8

# Database
DATABASE_URL=postgresql+asyncpg://gemini:gemini_dev@localhost:5432/gemini_mm

# Frontend
FRONTEND_URL=http://localhost:3000

# Data
DATA_RETENTION_DAYS=7
